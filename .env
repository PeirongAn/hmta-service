# LLM provider — OpenAI or any OpenAI-compatible endpoint
# Official OpenAI:
#   OPENAI_API_KEY=sk-...
#   OPENAI_BASE_URL=          (leave empty, defaults to api.openai.com)
#
# Third-party OpenAI-compatible endpoint example:
# OPENAI_API_KEY=sk-zk2e71d80c0be63a568d4071473450bf93568452c132eed7
# OPENAI_BASE_URL=https://api.zhizengzeng.com/v1/
# PLANNER_MODEL=deepseek-v3
# BUILDER_MODEL=deepseek-v3
# FIXER_MODEL=deepseek-v3
OPENAI_API_KEY=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
OPENAI_BASE_URL=https://openrouter.ai/api/v1

PLANNER_MODEL=openai/gpt-4o
BUILDER_MODEL=openai/gpt-4o
FIXER_MODEL=openai/gpt-4o-mini

# Reserved for future provider integrations. These are not wired yet.
ANTHROPIC_API_KEY=
COZE_API_KEY=

# Zenoh
ZENOH_ROUTER=tcp/localhost:7447

# Service settings
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
LOG_LEVEL=INFO

# LangSmith tracing (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=hmta-service
